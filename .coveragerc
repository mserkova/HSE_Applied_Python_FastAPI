[run]
source = app
omit = 
    */__init__.py
    */__pycache__/*
    tests/*
    */.venv/*

[report]
show_missing = True
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.:
    raise AssertionError
    raise NotImplementedError
    if TYPE_CHECKING:
    class .*\(.*\):